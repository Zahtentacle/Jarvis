<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jarvis.wablast">

    <queries>
        <package android:name="com.whatsapp" />
    </queries>

    <application
        android:allowBackup="true"
        android:label="Jarvis"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity android:name=".MainActivity" android:exported="true" android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service android:name=".JarvisAccessibility"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice"
                android:resource="@xml/jarvis_accessibility" />
        </service>

        <receiver android:name=".NextReceiver" android:exported="false">
            <intent-filter>
                <action android:name="JARVIS_NEXT" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
